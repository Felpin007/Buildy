{
  "name": "ai-structure-generator",
  "displayName": "AI Code Structure Generator",
  "description": "Generates project file structures from a specific JSON format, ideal for use with AI models like Google Gemini. Paste the AI-generated JSON to create files and folders.",
  "publisher": "FelpolinColorado",
  "version": "0.0.4",
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:structureView",
    "onView:copySystemView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "structure-generator-view-container",
          "title": "AI Structure Gen",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "structure-generator-view-container": [
        {
          "id": "structureView",
          "name": "Structure",
          "type": "webview",
          "contextualTitle": "Structure Generator"
        },
        {
          "id": "copySystemView",
          "name": "Copy System",
          "type": "webview",
          "contextualTitle": "Copy System"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.16",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "@vscode/codicons": "^0.0.36",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.23.0",
    "fs-extra": "^11.3.0",
    "lodash": "^4.17.21",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "simple-git": "^3.27.0"
  }
}
